@using RachaAiBlazor.Models

<div class="card shadow-sm mb-3 border-0 rounded-4">
    <div class="card-body d-flex justify-content-between align-items-center">

        <div>
            <h5 class="fw-bold mb-1">@Grupo.Nome</h5>

            <span class="badge bg-secondary fs-3 p-2">
                @Grupo.Categoria
            </span>
        </div>

      <div>
    <h5 class="fw-bold @(Grupo.TenhoCredito ? "text-success" : "text-danger")">
        @Grupo.Valor.ToString("C")
    </h5>

    <small>
        @(Grupo.TenhoCredito ? "Você tem crédito" : "Você está devendo")
    </small>
</div>

    </div>
</div>

@code {
    [Parameter]
    public Grupo Grupo { get; set; } = new();
}